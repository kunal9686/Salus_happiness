rules_version = '2';

/**
 * @name Firebase Security Rules: Salus Mental Wellness Platform
 * @author AI Security Architect
 * @version 1.1.0
 *
 * @description
 * This ruleset enforces a strict private-first model for Salus. 
 * All user data is restricted to the owner, while educational 
 * content like stories is public for all users to read.
 */
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // -------------------------------------------------------------------------
    // User Profile Rules (/users)
    // -------------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Prevent user enumeration
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      // -----------------------------------------------------------------------
      // Private User Subcollection Rules
      // -----------------------------------------------------------------------

      /**
       * Secures journal entries, mood logs, and goals.
       */
      match /journalEntries/{entryId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      match /moodLogs/{logId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      match /wellnessGoals/{goalId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      match /chatbotSessions/{sessionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        match /chatMessages/{messageId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId);
          allow update: if isExistingOwner(userId);
          allow delete: if isExistingOwner(userId);
        }
      }
    }

    // -------------------------------------------------------------------------
    // Public Content Rules
    // -------------------------------------------------------------------------

    /**
     * Resilience stories are read-only for all users.
     */
    match /stories/{storyId} {
      allow get, list: if true;
    }
  }
}